# --- Vite (browser-only variables must use VITE_ prefix) ---
# Deployed Certification.sol — required for wallet flows & dashboard reads.
VITE_CONTRACT_ADDRESS=
# Usually 11155111 for Sepolia.
VITE_DEFAULT_CHAIN_ID=11155111

# Optional: after a manifest match on /demo, POST to /api/verify-document (needs server secrets on Vercel).
VITE_ENABLE_ONCHAIN_DEMO=

# Optional: mount EnvTest + ContractTest in production builds (otherwise dev-only). Use 1 or true.
VITE_SHOW_DEBUG=

# Optional local hybrid dev: run `vercel dev` (Terminal A), then point Vite at its origin so /api/* proxies there.
# Example: http://127.0.0.1:3000
VITE_DEV_API_PROXY_TARGET=

# --- Hardhat & scripts ---
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR-INFURA-PROJECT-ID
PRIVATE_KEY=

# --- Vercel serverless: POST /api/verify-document ---
# Set as Vercel Environment Variables (Production / Preview):
# SEPOLIA_RPC_URL=
# CERTIFI_CONTRACT_ADDRESS=   # same contract as VITE_CONTRACT_ADDRESS

# Vercel Build Command is set in vercel.json to: npm run vercel-build
# (runs hardhat compile, then vite build — ensures artifacts exist for ABI imports)

ETHERSCAN_API_KEY=

# One-time demo issuance (signer must be INSTITUTION): CERTIFI_CONTRACT_ADDRESS=0x... npm run seed:demo
